# --- Postgres (pgvector) ---
# Te wartości używane są przez docker-compose do uruchomienia bazy
# ORAZ przez aplikację do połączenia.
POSTGRES_USER=sylabus
POSTGRES_PASSWORD=sylabus
POSTGRES_DB=sylabus

# Connection string używany przez aplikację. W docker-compose host = nazwa
# usługi `postgres`. Jeśli odpalasz aplikację poza Dockerem (np. `bun dev`),
# podmień na `localhost`.
DATABASE_URL=postgres://sylabus:sylabus@postgres:5432/sylabus

# --- Czat LLM (OpenAI-compatible API) ---
# Domyślnie lokalna Ollama (uruchamiana w docker-compose).
# Po pierwszym `docker compose up` ściągnij model czatu:
#   docker compose exec ollama ollama pull gemma4:26b
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
CHAT_MODEL=gemma4:26b
TOP_K=15

# --- Embeddingi (osobny endpoint, opcjonalnie) ---
# Domyślnie TEI z modelem sdadas/mmlw-retrieval-roberta-large-v2 (~1.3 GB, pobierany automatycznie).
# Jeśli puste — dziedziczy LLM_BASE_URL / LLM_API_KEY.
EMBED_BASE_URL=http://tei:80/v1
EMBED_API_KEY=tei
EMBED_MODEL=sdadas/mmlw-retrieval-roberta-large-v2

# --- Alternatywa: Ollama do embeddingów (nomic-embed-text) ---
# EMBED_BASE_URL=http://ollama:11434/v1
# EMBED_API_KEY=ollama
# EMBED_MODEL=nomic-embed-text

# --- Alternatywa: OpenAI do czatu i embeddingów ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# CHAT_MODEL=gpt-4o-mini
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small

# --- Storage PDFów ---
# Ścieżka wewnątrz kontenera (mountowana z hosta jako wolumen ./data/pdfs).
PDF_STORAGE_DIR=/data/pdfs

# --- Port aplikacji ---
PORT=8080
