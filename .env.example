# --- Postgres (pgvector) ---
# Te wartości używane są przez docker-compose do uruchomienia bazy
# ORAZ przez aplikację do połączenia.
POSTGRES_USER=sylabus
POSTGRES_PASSWORD=sylabus
POSTGRES_DB=sylabus

# Connection string używany przez aplikację. W docker-compose host = nazwa
# usługi `postgres`. Jeśli odpalasz aplikację poza Dockerem (np. `bun dev`),
# podmień na `localhost`.
DATABASE_URL=postgres://sylabus:sylabus@postgres:5432/sylabus

# --- LLM (OpenAI-compatible API) ---
# Domyślnie lokalna Ollama (uruchamiana w docker-compose).
# Po pierwszym `docker compose up` ściągnij modele:
#   docker compose exec ollama ollama pull gemma2:2b
#   docker compose exec ollama ollama pull nomic-embed-text
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
CHAT_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
TOP_K=5

# --- Storage PDFów ---
# Ścieżka wewnątrz kontenera (mountowana z hosta jako wolumen ./data/pdfs).
PDF_STORAGE_DIR=/data/pdfs

# --- Port aplikacji ---
PORT=8080

# --- Alternatywy (odkomentuj jeśli zamiast Ollamy chcesz np. OpenAI) ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# CHAT_MODEL=gpt-5-nano
# EMBED_MODEL=text-embedding-3-small
